// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  LECTURER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ExamMode {
  MANUAL
  RANDOM_N
  BY_TYPE
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  ESSAY
}

enum QuestionFormat {
  KNOWLEDGE
  UNDERSTANDING
  APPLYING
  ADVANCED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionRating {
  EXCELLENT
  GOOD
  AVERAGE
  POOR
}

enum SubmissionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FileType {
  AUDIO
  IMAGE
  VIDEO
}

enum FileStatus {
  PENDING
  AVAILABLE
  DELETED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  SYSTEM
}

model User {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  full_name           String
  email               String              @unique
  password            String?
  role                UserRole            @default(STUDENT)
  status              UserStatus          @default(ACTIVE)
  school              String?
  phone               String?
  address             String?
  accounts            Account[]
  exams               Exam[]
  topics              Topic[]
  submissions         Submission[]
  registrations       ExamRegistration[]
  receivedNotifications Notification[]    @relation("ReceivedNotifications")
  sentNotifications   Notification[]       @relation("SentNotifications")
  files               File[]               @relation("UploadedFiles")

  @@map("users")

  @@index([role])
  @@index([status])
}

model Account {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted               Boolean  @default(false)
  deleted_at               DateTime?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  user_id                  String   @db.Uuid
  provider                 String   @default("local")
  provider_id              String?
  refresh_token_hash       String?
  expires_at               BigInt?
  user                     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("accounts")

  @@unique([user_id, provider])
}

model Exam {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted        Boolean            @default(false)
  deleted_at        DateTime?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  lecturer_id       String             @db.Uuid
  topic_id          String             @db.Uuid
  title             String
  exam_start_time   DateTime
  exam_end_time     DateTime
  duration          Int
  practice          Boolean            @default(false)
  mode              ExamMode           @default(MANUAL)
  sample_size       Int?
  distribution      String?
  is_public         Boolean            @default(false)
  submissions       Submission[]
  questions         ExamQuestions[]
  registrations     ExamRegistration[]
  lecturer          User               @relation(fields: [lecturer_id], references: [id], onDelete: Cascade)
  topic             Topic              @relation(fields: [topic_id], references: [id], onDelete: Cascade)

  @@map("exams")

  @@index([lecturer_id])
  @@index([topic_id])
}

model Topic {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  created_by  String    @db.Uuid
  name        String

  exams       Exam[]
  chapters    Chapter[]
  creator     User      @relation(fields: [created_by], references: [id], onDelete: Cascade)

  @@map("topics")

  @@index([created_by])
}

model Chapter {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  topic_id    String    @db.Uuid
  parent_id   String?   @db.Uuid
  name        String
  order       Int
  topic       Topic     @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  parent      Chapter?  @relation("ChapterToChapter", fields: [parent_id], references: [id], onDelete: Cascade)
  children    Chapter[] @relation("ChapterToChapter")
  questions   Question[]

  @@map("chapters")

  @@index([topic_id, order])
  @@index([parent_id])
}

model Submission {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted    Boolean              @default(false)
  deleted_at    DateTime?
  created_at    DateTime             @default(now())
  updated_at    DateTime             @updatedAt
  exam_id       String               @db.Uuid
  student_id    String               @db.Uuid
  total_score   Decimal?             @db.Decimal(10, 2)
  rating        SubmissionRating?
  start_time    DateTime?
  end_time      DateTime?
  status        SubmissionStatus     @default(IN_PROGRESS)
  questions     SubmissionQuestions[]
  exam          Exam                 @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  student       User                 @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@map("submissions")

  @@index([exam_id])
  @@index([student_id])
  @@index([status])
}

model Question {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted       Boolean              @default(false)
  deleted_at       DateTime?
  created_at       DateTime             @default(now())
  updated_at       DateTime             @updatedAt
  question_text    String
  chapter_id       String               @db.Uuid
  options          String?
  correct_answer   String?
  question_type    QuestionType
  question_format  QuestionFormat
  submissions      SubmissionQuestions[]
  exams            ExamQuestions[]
  files            QuestionFiles[]
  chapter          Chapter              @relation(fields: [chapter_id], references: [id], onDelete: Cascade)

  @@map("questions")

  @@index([chapter_id])
  @@index([question_type, question_format])
}

model QuestionFiles {
  question_id String   @db.Uuid
  file_id     String   @db.Uuid
  order       Int
  question    Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  file        File     @relation(fields: [file_id], references: [id], onDelete: Cascade)

  @@unique([question_id, file_id])
  @@map("question_files")
}

model ExamQuestions {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted  Boolean  @default(false)
  deleted_at  DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  exam_id     String   @db.Uuid
  question_id String   @db.Uuid
  exam        Exam     @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@unique([exam_id, question_id])
  @@map("exam_questions")
}

model SubmissionQuestions {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted    Boolean    @default(false)
  deleted_at    DateTime?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  submission_id String     @db.Uuid
  question_id   String     @db.Uuid
  options       String?
  answer        String?
  score         Decimal?   @db.Decimal(10, 2)
  is_correct    Boolean    @default(false)
  submission    Submission @relation(fields: [submission_id], references: [id], onDelete: Cascade)
  question      Question   @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@unique([submission_id, question_id])
  @@map("submission_questions")
}

model ExamRegistration {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted  Boolean            @default(false)
  deleted_at  DateTime?
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt
  exam_id     String             @db.Uuid
  student_id  String             @db.Uuid
  status      RegistrationStatus @default(PENDING)
  exam        Exam               @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  student     User               @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([exam_id, student_id])
  @@map("exam_registrations")

  @@index([exam_id, status])
  @@index([student_id])
}

model File {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid 
  name          String
  url           String
  s3_key        String
  type          FileType
  size          Int?
  entity_type   String?
  entity_id     String?
  uploaded_by   String          @db.Uuid
  uploaded_at   DateTime        @default(now())
  status        FileStatus      @default(PENDING)
  uploadedBy    User            @relation("UploadedFiles", fields: [uploaded_by], references: [id], onDelete: Cascade)
  questions     QuestionFiles[]

  @@map("files")

  @@index([entity_type, entity_id])
  @@index([uploaded_by])
}

model Notification {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_deleted   Boolean          @default(false)
  deleted_at   DateTime?
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  recipient_id String           @db.Uuid
  sender_id    String?          @db.Uuid
  type         NotificationType
  title        String
  content      String
  target_id    String?
  target_type  String?
  is_read      Boolean          @default(false)
  link         String?
  recipient    User             @relation("ReceivedNotifications", fields: [recipient_id], references: [id], onDelete: Cascade)
  sender       User?            @relation("SentNotifications", fields: [sender_id], references: [id], onDelete: SetNull)

  @@map("notifications")

  @@index([recipient_id, is_read])
  @@index([created_at(sort: Desc)])
}
